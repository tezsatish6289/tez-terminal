
{
  "entities": {
    "WebhookConfig": {
      "title": "WebhookConfig",
      "type": "object",
      "description": "Configuration for an external signal bridge.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "secretKey": { "type": "string" },
        "endpointUrl": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "secretKey"]
    },
    "Signal": {
      "title": "Signal",
      "type": "object",
      "description": "A trading signal received from a bridge.",
      "properties": {
        "id": { "type": "string" },
        "webhookId": { "type": "string" },
        "receivedAt": { "type": "string", "format": "date-time" },
        "symbol": { "type": "string" },
        "type": { "type": "string", "enum": ["BUY", "SELL", "NEUTRAL"] },
        "payload": { "type": "string" }
      },
      "required": ["id", "symbol", "type", "receivedAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/webhooks/{webhookId}": {
      "schema": "#/backend/entities/WebhookConfig",
      "description": "Global bridge configurations managed by the admin."
    },
    "/signals/{signalId}": {
      "schema": "#/backend/entities/Signal",
      "description": "Global stream of signals for all consumers."
    }
  }
}
