
{
  "entities": {
    "WebhookConfig": {
      "title": "WebhookConfig",
      "type": "object",
      "description": "Global bridge configurations managed exclusively by the terminal admin.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "secretKey": { "type": "string" },
        "endpointUrl": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "secretKey"]
    },
    "Signal": {
      "title": "Signal",
      "type": "object",
      "description": "A real-time market alert received via the bridge, shared with all users.",
      "properties": {
        "id": { "type": "string" },
        "webhookId": { "type": "string" },
        "receivedAt": { "type": "string", "format": "date-time" },
        "symbol": { "type": "string" },
        "type": { "type": "string", "enum": ["BUY", "SELL", "NEUTRAL"] },
        "price": { "type": "number", "description": "The price at which the alert was triggered." },
        "payload": { "type": "string" },
        "note": { "type": "string" },
        "source": { "type": "string" },
        "timeframe": { "type": "string", "description": "The timeframe of the signal (e.g. 1, 5, 15, 60, D)" }
      },
      "required": ["id", "symbol", "type", "receivedAt"]
    },
    "SystemLog": {
      "title": "SystemLog",
      "type": "object",
      "description": "Technical logs for debugging webhook ingestion and system events.",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "level": { "type": "string", "enum": ["INFO", "WARN", "ERROR"] },
        "message": { "type": "string" },
        "details": { "type": "string" },
        "webhookId": { "type": "string" }
      },
      "required": ["id", "timestamp", "level", "message"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/webhooks/{webhookId}": {
      "schema": "#/backend/entities/WebhookConfig",
      "description": "Global bridge configurations managed exclusively by hello@tezterminal.com."
    },
    "/signals/{signalId}": {
      "schema": "#/backend/entities/Signal",
      "description": "The real-time global feed of market alerts consumed by all traders."
    },
    "/logs/{logId}": {
      "schema": "#/backend/entities/SystemLog",
      "description": "System debugging logs."
    }
  }
}
