
{
  "entities": {
    "WebhookConfiguration": {
      "title": "WebhookConfiguration",
      "type": "object",
      "description": "A configuration for a TradingView webhook endpoint.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "userId": { "type": "string" },
        "secretKey": { "type": "string" },
        "isActive": { "type": "boolean" },
        "endpointUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "userId", "secretKey"]
    },
    "WebhookEvent": {
      "title": "WebhookEvent",
      "type": "object",
      "description": "An individual signal received from an external source.",
      "properties": {
        "id": { "type": "string" },
        "webhookConfigurationId": { "type": "string" },
        "userId": { "type": "string" },
        "receivedAt": { "type": "string", "format": "date-time" },
        "payload": { "type": "string" },
        "sourceIp": { "type": "string" },
        "processingStatus": { "type": "string", "enum": ["PROCESSED", "ERROR"] }
      },
      "required": ["id", "userId", "receivedAt", "payload"]
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/users/{userId}/webhookConfigurations/{configId}": {
      "schema": "#/backend/entities/WebhookConfiguration",
      "description": "User-specific webhook endpoint settings."
    },
    "/users/{userId}/webhookEvents/{eventId}": {
      "schema": "#/backend/entities/WebhookEvent",
      "description": "User-specific log of received trading signals."
    }
  }
}
