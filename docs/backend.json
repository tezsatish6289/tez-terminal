
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "User account information and role.",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "USER"] },
        "subscriptionPlan": { "type": "string", "enum": ["BASIC", "PRO", "ELITE"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "role"]
    },
    "WebhookConfiguration": {
      "title": "WebhookConfiguration",
      "type": "object",
      "description": "A global configuration for a TradingView webhook endpoint managed by Admins.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "adminId": { "type": "string" },
        "secretKey": { "type": "string" },
        "isActive": { "type": "boolean" },
        "endpointUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "adminId", "secretKey"]
    },
    "Signal": {
      "title": "Signal",
      "type": "object",
      "description": "A trading signal received from a webhook, consumed by users.",
      "properties": {
        "id": { "type": "string" },
        "webhookId": { "type": "string" },
        "receivedAt": { "type": "string", "format": "date-time" },
        "payload": { "type": "string" },
        "symbol": { "type": "string" },
        "type": { "type": "string", "enum": ["BUY", "SELL"] },
        "processingStatus": { "type": "string" }
      },
      "required": ["id", "webhookId", "receivedAt", "payload"]
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Individual user profiles including roles."
    },
    "/webhooks/{webhookId}": {
      "schema": "#/backend/entities/WebhookConfiguration",
      "description": "Global webhook configurations managed by admins."
    },
    "/signals/{signalId}": {
      "schema": "#/backend/entities/Signal",
      "description": "Global stream of signals for all users."
    }
  }
}
