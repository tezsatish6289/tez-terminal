
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is the designated terminal admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "hello@tezterminal.com";
    }

    // Webhook Configurations: 
    // allow read: if true is required for the API route bridge to validate the secret key.
    // allow write: is strictly reserved for the terminal admin.
    match /webhooks/{webhookId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // Signals (Alerts): Anyone authenticated can read the global stream.
    // allow create: if true permits the Ingestion Bridge to post new signals.
    match /signals/{signalId} {
      allow read: if request.auth != null;
      allow create: if true; 
      allow update, delete: if isAdmin();
    }
  }
}
