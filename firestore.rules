
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user owns the document path
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      match /webhookConfigurations/{configId} {
        // User can manage their own configurations
        allow read, write: if isOwner(userId);
        
        // ALLOW: Ingestion route needs to read config to verify secretKey
        // In a prototype with Client SDK on server, we allow public GET for ingestion verification
        // assuming the configId is known only to the system/user.
        allow get: if true; 
      }

      match /webhookEvents/{eventId} {
        // User can read their own events
        allow read: if isOwner(userId);
        
        // ALLOW: Ingestion route needs to write events
        // For prototype simplicity, we allow public creation if it's the right path.
        // In production, we'd use a service account (Admin SDK).
        allow create: if true; 
        allow update, delete: if isOwner(userId);
      }
    }
  }
}
