rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is the designated terminal admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == "hello@tezterminal.com";
    }

    // Webhook Configurations
    match /webhooks/{webhookId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // Signals (Idea Stream)
    // Explicitly allow list and get to ensure filtered queries (listing) work for all authenticated users.
    match /signals/{signalId} {
      allow list, get: if request.auth != null;
      // API Route creates signals without auth.
      allow create: if true; 
      allow update, delete: if isAdmin();
    }

    // Logs: Technical audit trail.
    match /logs/{logId} {
      // Only Admin can read/list debugging logs.
      allow list, get: if isAdmin();
      // Public creation allowed for the ingestion node.
      allow create: if true;
      allow update, delete: if false;
    }
    
    // Deployment Trigger: 2024-05-23 16:15 - Explicit collection list permission deployment.
  }
}