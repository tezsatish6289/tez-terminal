
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is the designated terminal admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == "hello@tezterminal.com";
    }

    // Signals (Idea Stream)
    match /signals/{document=**} {
      allow read: if true; 
      allow create: if true; 
      allow update: if true; 
      allow delete: if isAdmin();
    }

    // Webhook Configurations
    match /webhooks/{webhookId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // Sentiment signals from external indicators
    match /sentiment_signals/{document=**} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // App Configuration (sentiment K value, thresholds, etc.)
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Logs: Technical audit trail.
    match /logs/{logId} {
      allow list, get: if isAdmin();
      allow create: if true;
      allow update, delete: if false;
    }

    // Users: only the owning user can read their own doc from the client.
    // Server-side Admin SDK bypasses these rules entirely.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Telegram preferences: only the owning user can read/write from the client.
    match /telegram_preferences/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Telegram link tokens: client needs to create these (from the settings page).
    // Reading/deleting is handled server-side via Admin SDK.
    match /telegram_link_tokens/{tokenId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Signal events: readable by any authenticated user (Live Updates pane).
    match /signal_events/{eventId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Tracked signals: per-user per-signal opt-in for TP/SL updates.
    match /tracked_signals/{trackId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Subscriptions: user can read their own, server handles writes.
    match /subscriptions/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Payments: user can read their own payments, server handles writes.
    match /payments/{paymentId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Referral commissions: referrer can read their own, server handles writes.
    match /referral_commissions/{commissionId} {
      allow read: if request.auth != null
        && resource.data.referrerId == request.auth.uid;
      allow write: if false;
    }

    // Referral payouts: referrer can read their own, server handles writes.
    match /referral_payouts/{payoutId} {
      allow read: if request.auth != null
        && resource.data.referrerId == request.auth.uid;
      allow write: if false;
    }
  }
}
