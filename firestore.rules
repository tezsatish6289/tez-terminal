
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is the designated admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "hello@tezterminal.com";
    }

    // Webhooks: Only Admin can manage. Anyone can 'get' if they know the ID (for API route)
    match /webhooks/{webhookId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // Signals: Anyone can read the stream.
    match /signals/{signalId} {
      allow read: if request.auth != null;
      allow create: if true; // Public ingestion for TradingView bridges
      allow update, delete: if isAdmin();
    }
  }
}
