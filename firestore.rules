
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is the designated terminal admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == "hello@tezterminal.com";
    }

    // Signals (Idea Stream)
    match /signals/{document=**} {
      // Shared market ideas are public in this app's vision
      allow read: if true; 
      // Webhooks create these (unauthenticated entry point)
      allow create: if true; 
      // Allow the Server Cron to update prices and performance metrics
      allow update: if true; 
      // Only the admin can delete signal history
      allow delete: if isAdmin();
    }

    // Webhook Configurations
    match /webhooks/{webhookId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // App Configuration (sentiment K value, thresholds, etc.)
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Logs: Technical audit trail.
    match /logs/{logId} {
      allow list, get: if isAdmin();
      allow create: if true;
      allow update, delete: if false;
    }

    // Users: Telegram connection data + profile
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if true;
    }

    // Telegram preferences: per-user alert filters
    match /telegram_preferences/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if true;
    }

    // Telegram link tokens: ephemeral one-time-use tokens
    match /telegram_link_tokens/{tokenId} {
      allow read, write: if true;
    }

    // Signal events: TP/SL/new signal events for Telegram fan-out
    match /signal_events/{eventId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }
  }
}
