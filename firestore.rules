rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * TEZTERMINAL ANTIGRAVITY SECURITY RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      match /webhookConfigurations/{webhookConfigurationId} {
        // Allow GET for webhook ingestion (server-side check)
        // In production, this would be more restricted, but for the terminal prototype, 
        // we allow path-based retrieval to validate secret keys.
        allow get: if true; 
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      match /webhookEvents/{webhookEventId} {
        allow get, list: if isOwner(userId);
        // Allow CREATE for webhook ingestion (server-side write)
        allow create: if request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}