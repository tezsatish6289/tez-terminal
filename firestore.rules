
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is the designated terminal admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "hello@tezterminal.com";
    }

    // Webhook Configurations: Only hello@tezterminal.com can write.
    // Read is allowed for everyone to facilitate client-side checks/logic.
    match /webhooks/{webhookId} {
      allow read: if request.auth != null; 
      allow write: if isAdmin();
    }

    // Signals (Alerts): Anyone authenticated can read the global stream.
    // Public 'create' is allowed to facilitate ingestion from TradingView/API.
    match /signals/{signalId} {
      allow read: if request.auth != null;
      allow create: if true; 
      allow update, delete: if isAdmin();
    }
  }
}
