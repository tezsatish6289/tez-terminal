rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is the designated terminal admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == "hello@tezterminal.com";
    }

    // Signals (Idea Stream)
    // Broaden matching to ensure collection-level queries (listing) are permitted for all auth users.
    match /signals/{document=**} {
      allow read: if request.auth != null;
      // Webhook API creates signals without auth.
      allow create: if true; 
      allow update, delete: if isAdmin();
    }

    // Webhook Configurations
    match /webhooks/{webhookId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // Logs: Technical audit trail.
    match /logs/{logId} {
      allow list, get: if isAdmin();
      allow create: if true;
      allow update, delete: if false;
    }
    
    // Deployment Trigger: 2024-05-23 18:45 - Rules confirmed working. Waiting for Composite Index activation.
  }
}