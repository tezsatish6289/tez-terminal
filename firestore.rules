
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is the designated terminal admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == "hello@tezterminal.com";
    }

    // Signals (Idea Stream)
    match /signals/{document=**} {
      // Shared market ideas are public in this app's vision
      allow read: if true; 
      // Webhooks create these (unauthenticated entry point)
      allow create: if true; 
      // Allow the Server Cron to update prices and performance metrics
      allow update: if true; 
      // Only the admin can delete signal history
      allow delete: if isAdmin();
    }

    // Webhook Configurations
    match /webhooks/{webhookId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // Logs: Technical audit trail.
    match /logs/{logId} {
      allow list, get: if isAdmin();
      allow create: if true;
      allow update, delete: if false;
    }
    
    // Deployment Trigger: 2024-05-24 11:30 - Enabled 24/7 Global Cron Sync.
  }
}
