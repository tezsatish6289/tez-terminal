rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is the designated terminal admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == "hello@tezterminal.com";
    }

    // Webhook Configurations: 
    // Public read is required for the API route to verify the bridge.
    // Admin has full control.
    match /webhooks/{webhookId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // Signals (Alerts): Anyone authenticated can read the global stream.
    // Using recursive wildcard {document=**} to ensure collection-level lists are permitted.
    match /signals/{document=**} {
      // Explicitly allow both 'get' and 'list' for authenticated users
      allow read: if request.auth != null;
      // API Route (unauthenticated) needs to create signals.
      allow create: if true; 
      allow update, delete: if isAdmin();
    }

    // Logs: Technical audit trail.
    match /logs/{document=**} {
      // Only Admin can read debugging logs.
      allow read: if isAdmin();
      // Public creation allowed for the ingestion node to log hits.
      allow create: if true;
      allow update, delete: if false;
    }
    
    // Deployment Trigger: 2024-05-23 14:15 - Recursive wildcard implementation for query stability.
  }
}