
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is the designated terminal admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == "hello@tezterminal.com";
    }

    // Signals (Idea Stream)
    match /signals/{document=**} {
      allow read: if request.auth != null;
      allow create: if true; 
      // Allow updates to performance tracking fields for the backend cron or admin
      allow update: if request.auth != null;
      allow delete: if isAdmin();
    }

    // Webhook Configurations
    match /webhooks/{webhookId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // Logs: Technical audit trail.
    match /logs/{logId} {
      allow list, get: if isAdmin();
      allow create: if true;
      allow update, delete: if false;
    }
    
    // Deployment Trigger: 2024-05-24 10:15 - Enabled Signal Performance Updates.
  }
}
